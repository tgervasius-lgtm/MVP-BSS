# Never commit real credentials. Production secrets belong in the platform secret store.
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
PUBLIC_ORIGIN=http://127.0.0.1:3000
# Local development default used by compose.dev.yml. Production must use the
# least-privileged bss_app role created by the deployment operator.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/bss
DATABASE_SSL=false
# Maximum connections per backend instance; size against the managed PostgreSQL limit.
DATABASE_POOL_MAX=10
# Optional PEM certificate from the platform secret store for a private PostgreSQL CA.
DATABASE_SSL_CA=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
COOKIE_SECURE=false
# Production: false or an explicit comma-separated IP/CIDR allowlist; never true.
TRUST_PROXY=false
LOG_LEVEL=info
RFID_UID_PEPPER=replace-with-at-least-32-random-characters
DEVICE_CREDENTIAL_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
TERMINAL_ACTIVATION_CODE=replace-with-a-random-pairing-code
# Optional: serve the built frontend and API from one origin.
FRONTEND_ROOT=../dist

# Required only for the one-time bootstrap command on a new installation.
BSS_BOOTSTRAP_ORGANIZATION_NAME=BSS d.o.o.
BSS_BOOTSTRAP_ADMIN_EMAIL=admin@example.hr
BSS_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
BSS_BOOTSTRAP_TIMEZONE=Europe/Zagreb

# Optional local integration-test database. Never point this at shared or
# production data; the suite creates and drops temporary roles and records.
# BSS_TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/bss_test
# BSS_REQUIRE_POSTGRES_TESTS=true
