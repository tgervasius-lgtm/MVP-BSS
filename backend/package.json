{
  "name": "@bss/backend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-static.mjs",
    "dev": "tsx watch src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "lint:openapi": "redocly lint ../openapi/bss-mvp-api-v1.yaml",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "migrate:prod": "node dist/src/db/migrate.js up",
    "bootstrap": "tsx src/db/bootstrap.ts",
    "bootstrap:prod": "node dist/src/db/bootstrap.js",
    "start": "node dist/src/server.js",
    "test": "node --import tsx --test test/unit/*.test.ts test/contract/*.test.ts test/integration/*.test.ts",
    "test:unit": "node --import tsx --test test/unit/*.test.ts test/contract/*.test.ts",
    "test:integration": "node --import tsx --test test/integration/*.test.ts",
    "check": "npm run lint:openapi && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/cookie": "11.1.1",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/static": "^10.1.0",
    "@fontsource/noto-sans": "^5.2.10",
    "@node-rs/argon2": "2.0.2",
    "exceljs": "^4.4.0",
    "fastify": "5.10.0",
    "fastify-raw-body": "^5.0.0",
    "pdfkit": "^0.19.1",
    "pg": "8.22.0"
  },
  "overrides": {
    "exceljs": {
      "uuid": "11.1.1"
    }
  },
  "devDependencies": {
    "@redocly/cli": "2.39.0",
    "@types/node": "24.10.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "8.16.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "yaml": "2.9.0"
  }
}
