{
  "name": "@bss/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "start": "node dist/server.js",
    "test": "node --import tsx --test test/unit/*.test.ts test/contract/*.test.ts test/integration/*.test.ts",
    "test:unit": "node --import tsx --test test/unit/*.test.ts test/contract/*.test.ts",
    "test:integration": "node --import tsx --test test/integration/*.test.ts",
    "check": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/cookie": "11.1.1",
    "@fastify/rate-limit": "11.1.0",
    "@node-rs/argon2": "2.0.2",
    "fastify": "5.10.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "8.16.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "yaml": "2.9.0"
  }
}
